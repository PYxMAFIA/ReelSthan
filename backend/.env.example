# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/reelsthan

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend URL (for email links)
BACKEND_URL=http://localhost:3000

# ImageKit Configuration (for image/video uploads)
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# Email Configuration (for verification/password reset)
GMAIL_USER=your_email@gmail.com
GOOGLE_APP_PASSWORD=your_app_password
# OR use Mailtrap for testing
MAILTRAP_TOKEN=your_mailtrap_token

# Pexels API (for fetching video content)
PEXELS_API_KEY=your_pexels_api_key
